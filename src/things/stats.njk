---
title: stats
---

<h1>Game stats</h1>
<p>
    Did you know that LinkedIn has games? They're the only thing I use that
    site for anymore. Queens is a very solid evolution of Sudoku.
</p>
<section>
    <h2>Latest</h2>
    <ul role="list" class="grid">
        {% for queen in queens|latest|take(1) %}
            <li class="box" data-cols="1" data-cols@s="1">
                <span class="titlebar flex-row justify-content:center align-items:center">{{ queen.date }}</span>
                <div class="flex-column align-items:center crowded">
                    <svg xmlns="http://www.w3.org/2000/svg"
                         width="36"
                         height="36"
                         viewBox="0 0 24 24"
                         fill="none"
                         stroke="currentColor"
                         stroke-width="2"
                         stroke-linecap="round"
                         stroke-linejoin="round"
                         class="lucide lucide-chess-queen-icon lucide-chess-queen">
                        <title>Queens symbol</title>
                        <path d="M4 20a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v1a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1z" />
                        <path d="m12.474 5.943 1.567 5.34a1 1 0 0 0 1.75.328l2.616-3.402" />
                        <path d="m20 9-3 9" />
                        <path d="m5.594 8.209 2.615 3.403a1 1 0 0 0 1.75-.329l1.567-5.34" />
                        <path d="M7 18 4 9" />
                        <circle cx="12" cy="4" r="2" /><circle cx="20" cy="7" r="2" /><circle cx="4" cy="7" r="2" />
                    </svg>
                    <a href="https://www.linkedin.com/games/queens/"
                       target="_blank"
                       ref="noreferrer"
                       class="allcaps">Queens</a>
                    <p class="<h2>">{{ queen.me|astimer }}</p>
                    <p class="bold">Daily avg.: {{ queen.avg|astimer }}</p>
                    <chip class="{% if queen.diff > 0 %}bad{% else %}ok{% endif %} flex-row crowded align-items:center">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             width="16"
                             height="16"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="2"
                             stroke-linecap="round"
                             stroke-linejoin="round"
                             class="lucide lucide-timer-icon lucide-timer">
                            <title>Timer icon</title>
                            <line x1="10" x2="14" y1="2" y2="2" />
                            <line x1="12" x2="15" y1="14" y2="11" />
                            <circle cx="12" cy="14" r="8" />
                        </svg>
                        {{ queen.diff|astimer("diff") }}
                    </chip>
                </div>
            </li>
        {% endfor %}
        {% for tngo in tango|latest|take(1) %}
            <li class="box" data-cols="2" data-cols@s="1">
                <span class="titlebar flex-row justify-content:center align-items:center">{{ tngo.date }}</span>
                <div class="flex-column align-items:center crowded">
                    <svg xmlns="http://www.w3.org/2000/svg"
                         width="36"
                         height="36"
                         viewBox="0 0 24 24"
                         fill="none"
                         stroke="currentColor"
                         stroke-width="2"
                         stroke-linecap="round"
                         stroke-linejoin="round"
                         class="lucide lucide-sun-moon-icon lucide-sun-moon">
                        <title>tango symbol</title>
                        <path d="M12 2v2" />
                        <path d="M14.837 16.385a6 6 0 1 1-7.223-7.222c.624-.147.97.66.715 1.248a4 4 0 0 0 5.26 5.259c.589-.255 1.396.09 1.248.715" />
                        <path d="M16 12a4 4 0 0 0-4-4" />
                        <path d="m19 5-1.256 1.256" />
                        <path d="M20 12h2" />
                    </svg>
                    <a href="https://www.linkedin.com/games/tango/"
                       target="_blank"
                       ref="noreferrer"
                       class="allcaps">Tango</a>
                    <p class="<h2>">{{ tngo.me|astimer }}</p>
                    <p class="bold">Daily avg.: {{ tngo.avg|astimer }}</p>
                    <chip class="{% if tngo.diff > 0 %}bad{% else %}ok{% endif %} flex-row crowded align-items:center">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             width="16"
                             height="16"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="2"
                             stroke-linecap="round"
                             stroke-linejoin="round"
                             class="lucide lucide-timer-icon lucide-timer">
                            <title>Timer icon</title>
                            <line x1="10" x2="14" y1="2" y2="2" />
                            <line x1="12" x2="15" y1="14" y2="11" />
                            <circle cx="12" cy="14" r="8" />
                        </svg>
                        {{ tngo.diff|astimer("diff") }}
                    </chip>
                </div>
            </li>
        {% endfor %}
        {% for sudoku in minisudoku|latest|take(1) %}
            <li class="box" data-cols="3" data-cols@s="1">
                <span class="titlebar flex-row justify-content:center align-items:center">{{ sudoku.date }}</span>
                <div class="flex-column align-items:center crowded">
                    <svg xmlns="http://www.w3.org/2000/svg"
                         width="36"
                         height="36"
                         viewBox="0 0 24 24"
                         fill="none"
                         stroke="currentColor"
                         stroke-width="2"
                         stroke-linecap="round"
                         stroke-linejoin="round"
                         class="lucide lucide-grid3x3-icon lucide-grid-3x3">
                        <title>Sudoku symbol</title>
                        <rect width="18" height="18" x="3" y="3" rx="2" />
                        <path d="M3 9h18" />
                        <path d="M3 15h18" />
                        <path d="M9 3v18" />
                        <path d="M15 3v18" />
                    </svg>
                    <a href="https://www.linkedin.com/games/mini-sudoku/"
                       target="_blank"
                       ref="noreferrer"
                       class="allcaps">sudoku</a>
                    <p class="<h2>">{{ sudoku.me|astimer }}</p>
                    <p class="bold">Daily avg.: {{ sudoku.avg|astimer }}</p>
                    <chip class="{% if sudoku.diff > 0 %}bad{% else %}ok{% endif %} flex-row crowded align-items:center">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             width="16"
                             height="16"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="2"
                             stroke-linecap="round"
                             stroke-linejoin="round"
                             class="lucide lucide-timer-icon lucide-timer">
                            <title>Timer icon</title>
                            <line x1="10" x2="14" y1="2" y2="2" />
                            <line x1="12" x2="15" y1="14" y2="11" />
                            <circle cx="12" cy="14" r="8" />
                        </svg>
                        {{ sudoku.diff|astimer("diff") }}
                    </chip>
                </div>
            </li>
        {% endfor %}
    </ul>
    <div>
        <table class="container width:100% shrink@s">
            <caption>History</caption>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Game</th>
                    <th>My time</th>
                    <th>Avg. time</th>
                    <th>Diff.</th>
                </tr>
            </thead>
            <tbody>
                {% set queensAnnotated = queens|annotate("game", "Queens") %}
                {% set tangoAnnotated = tango|annotate("game", "Tango") %}
                {% set minisudokuAnnotated = minisudoku|annotate("game", "Sudoku") %}
                {% for game in queensAnnotated|concat(tangoAnnotated)|concat(minisudokuAnnotated) %}
                    <tr>
                        <td>{{ game.date }}</td>
                        <td>{{ game.game }}</td>
                        <td>{{ game.me|astimer }}</td>
                        <td>{{ game.avg|astimer }}</td>
                        <td class="bold color border {% if game.diff < 0 %}ok{% else %}bad{% endif %}">{{ game.diff|astimer("diff") }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</section>
